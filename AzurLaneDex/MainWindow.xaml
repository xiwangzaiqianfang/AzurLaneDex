<Window x:Class="AzurLaneDex.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="碧蓝航线图鉴">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- 自定义 TitleBar -->
            <RowDefinition Height="*" />
            <!-- 主内容区域 -->
        </Grid.RowDefinitions>
        <!-- 自定义标题栏 -->
        <TitleBar x:Name="AppTitleBar"
                    Title="碧蓝航线图鉴"
                    Subtitle="Preview for WinUI3"
                    IsBackButtonVisible="True"
                    IsBackButtonEnabled="{x:Bind ContentFrame.CanGoBack, Mode=OneWay}"
                    BackRequested="TitleBar_BackRequested"
                    IsPaneToggleButtonVisible="True"
                    PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Titles/App_Icon.ico" />
            </TitleBar.IconSource>

        </TitleBar>
        <!-- 导航视图 -->
        <NavigationView x:Name="MainNavView" Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        IsPaneOpen="False"
                        PaneDisplayMode="Left"
                        SelectionFollowsFocus="Enabled"
                        ItemInvoked="MainNavView_ItemInvoked"
                        IsTabStop="True">
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Library" Content="舰船图鉴" Tag="MainPage" />
                <NavigationViewItem Icon="Calculator" Content="阵营科技" Tag="CampTechPage" />
                <NavigationViewItem Icon="Manage" Content="属性加成" Tag="AttrBonusPage" />
                <NavigationViewItem>
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE780;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>统计</NavigationViewItem.Content>
                    <NavigationViewItem.Tag>StatsPage</NavigationViewItem.Tag>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="帐户" Tag="AccountPage" Icon="Contact"/>
                <NavigationViewItem Content="帮助" Tag="HelpPage" Icon="Help" />
            </NavigationView.FooterMenuItems>
            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>