<Page x:Class="AzurLaneDex.Views.LogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:Microsoft.UI.Xaml.Controls"
      NavigationCacheMode="Disabled">
    <Page.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefault}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <StackPanel Orientation="Horizontal" Margin="20,20,20,12" Spacing="12">
            <Button x:Name="BackButton" Click="BackButton_Click" Content="设置" FontSize="28" FontWeight="SemiBold" Margin="0,2,0,0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="返回" VerticalAlignment="Center"/>
            <FontIcon Glyph="&#xE974;" FontFamily="Segoe Fluent Icons" FontSize="22" Margin="-20,3,-10,0" VerticalAlignment="Center"/>
            <TextBlock Text="日志记录" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20" Spacing="16">
                <!-- 启用日志开关 -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="启用日志记录" FontSize="14"/>
                            <TextBlock Text="记录所有操作（新增/编辑/删除舰船、状态变更、账户操作等）" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="EnableLogToggle" Grid.Column="1" OffContent="关" OnContent="开" Toggled="EnableLogToggle_Toggled" FlowDirection="RightToLeft"/>
                    </Grid>
                </Border>

                <!-- 日志保留天数 -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="日志保留天数" FontSize="14"/>
                            <TextBlock Text="超过此天数的日志文件将被自动删除" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <NumberBox x:Name="RetentionDaysBox" Minimum="1" Maximum="365" Value="30" SpinButtonPlacementMode="Inline" Width="160" ValueChanged="RetentionDaysBox_ValueChanged"/>
                            <TextBlock Text="天" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 导出日志 -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="导出日志" FontSize="14"/>
                            <TextBlock Text="将当前所有日志导出为一个文本文件" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="ExportLogButton" Click="ExportLogButton_Click" Content="导出"/>
                    </Grid>
                </Border>

                <!-- 状态信息 -->
                <TextBlock x:Name="StatusText" Text="就绪" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>