<Page x:Class="AzurLaneDex.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:AzurLaneDex.Converters"
      xmlns:views="using:AzurLaneDex.Views">

	<Page.Resources>
		<converters:BoolToCheckMarkConverter x:Key="BoolToCheckMark"/>
		<converters:BoolToBreakthroughTextConverter x:Key="BoolToBreakthroughText"/>
		<converters:BoolToHeartConverter x:Key="BoolToHeart"/>
		<converters:BoolToStarConverter x:Key="BoolToStar"/>
	</Page.Resources>

	<Grid>
		<Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
		</Grid.RowDefinitions>

        <!-- ===== InfoBar 容器 ===== -->
        <StackPanel Grid.Row="0" Margin="12,12,12,0" Spacing="8">
            <!-- 1. Beta 版提示 InfoBar -->
            <InfoBar x:Name="BetaInfoBar"
                 Title="测试版本"
                 Message="当前为预览版，请留意潜在的 bug，并在发现问题时向我们反馈。"
                 Severity="Warning"
                 IsOpen="True"
                 IsClosable="True">
                <InfoBar.ActionButton>
                    <HyperlinkButton Content="前往反馈" NavigateUri="https://github.com/xiwangzaiqianfang/AzurLaneDex/issues"/>
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- 2. 周年庆 InfoBar -->
            <InfoBar x:Name="AnniversaryInfoBar"
                 Title="🎉祝《碧蓝航线》九周年生日快乐！🎉"
                 IsOpen="True"
                 IsClosable="True">
                <InfoBar.ActionButton>
                    <HyperlinkButton Content="前往官方活动页面查看活动详情" NavigateUri="https://game.bilibili.com/blhx/2026-ninth-anniversary/h5/"/>
                </InfoBar.ActionButton>
            </InfoBar>
        </StackPanel>

        <!-- 独立工具栏 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="12">
            <SelectorBar x:Name="CategorySelector" Margin="0,0,0,0" SelectionChanged="CategorySelector_SelectionChanged">
                <SelectorBarItem Text="角色" Tag="Normal" />
                <SelectorBarItem Text="联动" Tag="Collab" />
                <SelectorBarItem Text="科研" Tag="Research" />
                <SelectorBarItem Text="META" Tag="META" />
            </SelectorBar>
            
            <AutoSuggestBox x:Name="SearchBox"
                            PlaceholderText="搜索舰船名"
                            Width="150"
                            QueryIcon="Find"
                            TextChanged="SearchBox_TextChanged"
                            SuggestionChosen="SearchBox_SuggestionChosen"
                            UpdateTextOnSelect="True" VerticalAlignment="Center">
                <AutoSuggestBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayText}" />
                    </DataTemplate>
                </AutoSuggestBox.ItemTemplate>
            </AutoSuggestBox>
            <ComboBox x:Name="SortCombo" SelectedIndex="0" SelectionChanged="SortCombo_SelectionChanged" VerticalAlignment="Center">
                <ComboBoxItem>按编号排序</ComboBoxItem>
                <ComboBoxItem>按图鉴排序</ComboBoxItem>
                <ComboBoxItem>按名称排序</ComboBoxItem>
                <ComboBoxItem>按稀有度排序</ComboBoxItem>
                <ComboBoxItem>按改造日期排序</ComboBoxItem>
                <ComboBoxItem>按兵装日期排序</ComboBoxItem>
                <ComboBoxItem>按获得状态排序</ComboBoxItem>
                <ComboBoxItem>按改造状态排序</ComboBoxItem>
                <ComboBoxItem>按突破状态排序</ComboBoxItem>
                <ComboBoxItem>按誓约状态排序</ComboBoxItem>
                <ComboBoxItem>按120级状态排序</ComboBoxItem>
                <ComboBoxItem>按兵装获得状态排序</ComboBoxItem>
            </ComboBox>
            <ToggleButton x:Name="SortOrderToggle" Content="升序" Checked="SortOrderToggle_Checked" Unchecked="SortOrderToggle_Unchecked"/>
            <Button x:Name="FilterButton" Content="筛选" Click="FilterButton_Click"/>
            <Button Content="重置并刷新" Click="ResetAndRefresh_Click"/>
            <Button x:Name="BatchOperationButton" Content="批量操作" Click="BatchOperation_Click"/>
            <Button x:Name="AddShipButton" Content="新建舰船" Click="AddShipButton_Click" Visibility="Collapsed"/>
        </StackPanel>

        <!-- 主体区域：左右两列 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="580"/>
                <!-- 左侧列表区域宽度固定 -->
                <ColumnDefinition Width="*"/>
                <!-- 右侧详情页自适应 -->
            </Grid.ColumnDefinitions>

            <!-- 左侧列表区域 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 表头 -->
                    <RowDefinition Height="*"/>
                    <!-- 列表 -->
                </Grid.RowDefinitions>

                <!-- 固定表头 -->
                <Grid Grid.Row="0" Height="32" Background="{ThemeResource CardBackgroundFillColorDefault}" Margin="12,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="SelectAllCheckBox" Grid.Column="0" VerticalAlignment="Center"
                              Margin="16,0,0,0" Padding="0" Checked="SelectAll_Checked" Unchecked="SelectAll_Unchecked"/>
                    <TextBlock Grid.Column="1" Text="编号" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="名称" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="获得" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="誓约" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="突破" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="120级" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="7" Text="改造" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="8" Text="兵装" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- 舰船列表 -->
                <ListView x:Name="ShipListView" Grid.Row="2" 
                          SelectionMode="Single" 
                          SelectionChanged="ShipListView_SelectionChanged"
                          RightTapped="ShipListView_RightTapped"
                          Margin="12,0,12,0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Name="ContextMenuOwned" Text="标记为已获得" Click="ContextMenu_Owned_Click"/>
                                        <MenuFlyoutItem x:Name="ContextMenuNotOwned" Text="标记为未获得" Click="ContextMenu_NotOwned_Click"/>
                                        <MenuFlyoutItem x:Name="ContextMenuMaxBreak" Text="标记为已满破" Click="ContextMenu_MaxBreak_Click"/>
                                        <MenuFlyoutItem x:Name="ContextMenuNotMaxBreak" Text="标记为未满破" Click="ContextMenu_NotMaxBreak_Click"/>
                                        <MenuFlyoutItem x:Name="ContextMenuLevel120" Text="标记为已120级" Click="ContextMenu_Level120_Click"/>
                                        <MenuFlyoutItem x:Name="ContextMenuNotLevel120" Text="标记为未120级" Click="ContextMenu_NotLevel120_Click"/>
                                        <MenuFlyoutItem x:Name="ContextMenuOath" Text="标记为已誓约" Click="ContextMenu_Oath_Click"/>
                                        <MenuFlyoutItem x:Name="ContextMenuNotOath" Text="标记为未誓约" Click="ContextMenu_NotOath_Click"/>
                                        <MenuFlyoutItem x:Name="ContextMenuRemodeled" Text="标记为已改造" Click="ContextMenu_Remodeled_Click"/>
                                        <MenuFlyoutItem x:Name="ContextMenuNotRemodeled" Text="标记为未改造" Click="ContextMenu_NotRemodeled_Click"/>
                                        <MenuFlyoutItem x:Name="ContextMenuSpecialGear" Text="标记为已拥有特殊兵装" Click="ContextMenu_SpecialGear_Click"/>
                                        <MenuFlyoutItem x:Name="ContextMenuNotSpecialGear" Text="标记为未拥有特殊兵装" Click="ContextMenu_NotSpecialGear_Click"/>
                                        <MenuFlyoutSeparator x:Name="SeparatorDelete"/>
                                        <MenuFlyoutItem x:Name="ContextMenuDelete" Text="删除舰船" Click="ContextMenu_Delete_Click" Foreground="Red"/>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                <TextBlock Grid.Column="1" Text="{Binding DisplayId}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding Owned, Converter={StaticResource BoolToCheckMark}}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding Oath, Converter={StaticResource BoolToHeart}}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="{Binding BreakthroughDisplay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="{Binding Level120, Converter={StaticResource BoolToStar}}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="7" Text="{Binding Remodeled, Converter={StaticResource BoolToCheckMark}}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="8" Text="{Binding SpecialGearObtained, Converter={StaticResource BoolToCheckMark}}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- 右侧详情区域 -->
            <views:ShipDetailControl x:Name="ShipDetailControl" Grid.Column="1" Margin="12,0,12,0"/>
        </Grid>
    </Grid>
</Page>