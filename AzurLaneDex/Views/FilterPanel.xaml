<UserControl
    x:Class="AzurLaneDex.Views.FilterPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="460">
            <StackPanel Margin="12">
                <!-- 舰种 -->
                <Expander Grid.Row="0" Header="舰种" HorizontalAlignment="Stretch" IsExpanded="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <CheckBox x:Name="ClassDD" Content="驱逐" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="ClassCL" Content="轻巡" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="ClassCA" Content="重巡" Margin="8,4,6,4" Width="50"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <CheckBox x:Name="ClassCB" Content="超巡" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="ClassBC" Content="战巡" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="ClassBB" Content="战列" Margin="8,4,6,4" Width="50"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <CheckBox x:Name="ClassBBV" Content="航战" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="ClassCV" Content="航母" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="ClassCVL" Content="轻航" Margin="8,4,6,4" Width="50"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                            <CheckBox x:Name="ClassAR" Content="维修" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="ClassSS" Content="潜艇" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="ClassSSV" Content="潜母" Margin="8,4,6,4" Width="50"/>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Orientation="Horizontal">
                            <CheckBox x:Name="ClassAE" Content="运输" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="ClassSail" Content="风帆" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="ClassOther" Content="其他" Margin="8,4,6,4" Width="50"/>
                        </StackPanel>

                    </Grid>
                </Expander>

                <!-- 阵营 -->
                <Expander Grid.Row="1" Header="阵营" HorizontalAlignment="Stretch" IsExpanded="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <CheckBox x:Name="FactionEU" Content="白鹰" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="FactionRN" Content="皇家" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="FactionIJN" Content="重樱" Margin="8,4,6,4" Width="80"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <CheckBox x:Name="FactionKMS" Content="铁血" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="FactionDragon" Content="东煌" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="FactionSN" Content="北方联合" Margin="8,4,6,4" Width="80"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <CheckBox x:Name="FactionFFNF" Content="自由鸢尾" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="FactionMNF" Content="维希教廷" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="FactionSardegna" Content="撒丁帝国" Margin="8,4,6,4" Width="80"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                            <CheckBox x:Name="FactionMETA" Content="META" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="FactionTempesta" Content="飓风" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="FactionOther" Content="其他" Margin="8,4,6,4" Width="80"/>
                        </StackPanel>
                    </Grid>
                </Expander>

                <!-- 稀有度 -->
                <Expander Grid.Row="2" Header="稀有度" HorizontalAlignment="Stretch" IsExpanded="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <CheckBox x:Name="RarityNormal" Content="普通" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="RarityRare" Content="稀有" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="RarityElite" Content="精锐" Margin="8,4,6,4" Width="80"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <CheckBox x:Name="RaritySuperRare" Content="超稀有" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="RarityLegendary" Content="海上传奇" Margin="8,4,6,4" Width="90"/>
                        </StackPanel>
                    </Grid>
                </Expander>

                <!-- 附加状态 -->
                <Expander Grid.Row="3" Header="附加状态" HorizontalAlignment="Stretch" IsExpanded="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <CheckBox x:Name="ExtraCanRemodel" Content="可改造" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="ExtraRemodeled" Content="已改造" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="ExtraMaxBreak" Content="已满破" Margin="8,4,6,4" Width="80"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <CheckBox x:Name="ExtraNotMaxBreak" Content="未满破" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="ExtraLevel120" Content="已120级" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="ExtraNotLevel120" Content="未120级" Margin="8,4,6,4" Width="80"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <CheckBox x:Name="ExtraOath" Content="已誓约" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="ExtraNotOath" Content="未誓约" Margin="8,4,6,4" Width="80"/>
                            <CheckBox x:Name="ExtraCanSpecial" Content="可拥有特殊兵装" Margin="8,4,6,4" Width="110"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                            <CheckBox x:Name="ExtraSpecialObtained" Content="已拥有特殊兵装" Margin="8,4,6,4" Width="110"/>
                        </StackPanel>
                    </Grid>
                </Expander>

                <!-- 属性加成 -->
                <Expander Grid.Row="4" Header="属性加成" HorizontalAlignment="Stretch" IsExpanded="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <CheckBox x:Name="AttrFirepower" Content="炮击" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="AttrAviation" Content="航空" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="AttrMobility" Content="机动" Margin="8,4,6,4" Width="50"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <CheckBox x:Name="AttrAA" Content="防空" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="AttrTorpedo" Content="雷击" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="AttrReload" Content="装填" Margin="8,4,6,4" Width="50"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <CheckBox x:Name="AttrDurability" Content="耐久" Margin="8,4,6,4" Width="50"/>
                            <CheckBox x:Name="AttrAntiSub" Content="反潜" Margin="8,4,6,4" Width="50"/>
                        </StackPanel>
                    </Grid>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>