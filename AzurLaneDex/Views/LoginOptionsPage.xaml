<Page
    x:Class="AzurLaneDex.Views.LoginOptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

	<Page.Resources>
		<Style x:Key="SettingsCardStyle" TargetType="Border">
			<Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefault}"/>
			<Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="16"/>
			<Setter Property="Margin" Value="0,0,0,0"/>
		</Style>
	</Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏（返回按钮 + 标题） -->
        <StackPanel Orientation="Horizontal" Margin="20,20,20,12" Spacing="12">
            <Button x:Name="BackButton" Click="BackButton_Click" Content="帐户" FontSize="28" FontWeight="SemiBold" Margin="0,2,0,0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="返回" VerticalAlignment="Center"/>
            <FontIcon Grid.Column="0" Glyph="&#xE974;" FontFamily="Segoe Fluent Icons" FontSize="22" Margin="-20,3,-10,0" VerticalAlignment="Center"/>
            <TextBlock Text="登录选项" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20" Spacing="16">
                <Border Style="{StaticResource SettingsCardStyle}">
					<Grid>
						<Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="启动时询问账号" FontSize="14"/>
						    <TextBlock Text="如果启用，每次启动都会显示账户选择窗口；否则将自动使用默认账户登录。" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
						</StackPanel>
                        <Grid Grid.Column="1" FlowDirection="RightToLeft">
						    <ToggleSwitch x:Name="AskAccountToggleSwitch" VerticalAlignment="Center" OffContent="" OnContent="" Toggled="AskAccountToggleSwitch_Toggled"/>
                            <TextBlock x:Name="StatusText" Text="关" Margin="50,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
					</Grid>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
					<Grid>
						<Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0">
                            <TextBlock Text="默认账户" FontSize="14"/>
                            <TextBlock Text="启动时不询问账户时，将自动登录此账户。" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
					    </StackPanel>
						<ComboBox Grid.Column="1" x:Name="DefaultAccountComboBox" MinWidth="150" VerticalAlignment="Center" SelectionChanged="DefaultAccountComboBox_SelectionChanged"/>
		            </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>