<ContentDialog x:Class="AzurLaneDex.Views.FirstRunDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               Title="初始化账户"
               PrimaryButtonText="创建"
               CloseButtonText="退出"
               DefaultButton="Primary">
    <StackPanel Spacing="12">
        <TextBox x:Name="NameBox" PlaceholderText="账户名" />
        <PasswordBox x:Name="PasswordBox" PlaceholderText="密码（可选）" />
        <TextBox x:Name="SecurityQuestionBox" Header="密保问题" PlaceholderText="例如：您的生日是？" Margin="0,8,0,0"/>
        <PasswordBox x:Name="SecurityAnswerBox" Header="密保答案" PlaceholderText="答案（用于找回密码）" Margin="0,8,0,0"/>
        <CheckBox x:Name="IsDeveloperCheckBox" Content="设为开发者账户" Visibility="Collapsed"/>
        <CheckBox x:Name="SetDefaultCheckBox" Content="设为默认账户" IsChecked="True" />
        <Button Content="选择头像" Click="SelectAvatar_Click" />
        <TextBlock x:Name="AvatarPathText" Text="未选择头像" FontSize="12" Foreground="Gray"/>
    </StackPanel>
</ContentDialog>