<UserControl
    x:Class="AzurLaneDex.Views.ShipDetailControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <UserControl.Resources>
        <Storyboard x:Name="AvatarFadeInStoryboard">
            <DoubleAnimation
            Storyboard.TargetName="ShipAvatarImage"
            Storyboard.TargetProperty="Opacity"
            From="0.0" To="1.0" Duration="0:0:0.1"
            EnableDependentAnimation="True" />
        </Storyboard>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" Margin="12">

            <!-- 基本信息卡片 -->
            <Border x:Name="BasicBorder"
                    Background="{ThemeResource CardBackgroundFillColorDefault}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,12"
                    Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <FontIcon Glyph="&#xE946;" FontFamily="Segoe Fluent Icons" FontSize="18" Margin="0,-4,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="基本信息" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:Name="EditShipButton" Grid.Column="1"
                                    Background="Transparent" BorderBrush="{ThemeResource ButtonBorderBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="8,4"
                                    Click="EditShipButton_Click"  ToolTipService.ToolTip="编辑舰船">
                            <FontIcon Glyph="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                    </Grid>

                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6" Background="Transparent" Margin="0,0,12,0">
                                <Image x:Name="ShipAvatarImage" Stretch="UniformToFill" Opacity="1"/>
                            </Border>
                            <TextBlock x:Name="ShipNameText" Grid.Column="1" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        </Grid>
                        <TextBlock Text="编号:" Grid.Row="1" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="ShipIdText" Grid.Row="1" Grid.Column="1"/>
                        <TextBlock Text="阵营:" Grid.Row="2" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="FactionText" Grid.Row="2" Grid.Column="1"/>
                        <TextBlock Text="舰种:" Grid.Row="3" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="ShipClassText" Grid.Row="3" Grid.Column="1"/>
                        <TextBlock Text="稀有度:" Grid.Row="4" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="RarityText" Grid.Row="4" Grid.Column="1"/>
                        <TextBlock Text="能否改造:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="CanRemodelText" Grid.Row="5" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="改造日期:" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="RemodelDateText" Grid.Row="6" Grid.Column="1" Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 状态操作卡片 -->
            <Border x:Name="StateBorder"
                    Background="{ThemeResource CardBackgroundFillColorDefault}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,12"
                    Padding="12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <FontIcon Glyph="&#xE835;" FontFamily="Segoe Fluent Icons" FontSize="18" Margin="0,-4,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="状态" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    </StackPanel>
                <CheckBox x:Name="OwnedCheckBox" Content="已获得" Checked="OnOwnedChanged" Unchecked="OnOwnedChanged"/>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                        <TextBlock Text="突破:" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Slider x:Name="BreakthroughSlider" Minimum="0" Maximum="3" TickFrequency="1" TickPlacement="BottomRight" 
                                Width="200" ValueChanged="OnBreakthroughChanged"/>
                        <TextBlock x:Name="BreakthroughValueText" VerticalAlignment="Center" Width="40"/>
                    </StackPanel>

                    <CheckBox x:Name="OathCheckBox" Content="已誓约" Margin="0,4,0,0" Checked="OnOathChanged" Unchecked="OnOathChanged"/>
                    <CheckBox x:Name="Level120CheckBox" Content="120级" Margin="0,4,0,0" Checked="OnLevel120Changed" Unchecked="OnLevel120Changed"/>
                    <CheckBox x:Name="RemodeledCheckBox" Content="已改造" Margin="0,4,0,0" Checked="OnRemodeledChanged" Unchecked="OnRemodeledChanged"/>
                    <CheckBox x:Name="SpecialGearObtainedCheckBox" Content="已获得专属兵装" Margin="0,4,0,0" Visibility="Collapsed"
                              Checked="OnSpecialGearObtainedChanged" Unchecked="OnSpecialGearObtainedChanged"/>
                </StackPanel>
            </Border>

            <!-- 获取方式卡片 -->
            <Border x:Name="AcquireBorder"
                    Background="{ThemeResource CardBackgroundFillColorDefault}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,12"
                    Padding="12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <FontIcon Glyph="&#xE82E;" FontFamily="Segoe Fluent Icons" FontSize="18" Margin="0,-4,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="获取方式" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    </StackPanel>
                    <TextBlock Text="主要获取:" Grid.Row="0" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="AcquireMainText" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <TextBlock x:Name="AcquireDetailText" Grid.Row="1" Grid.Column="0" TextWrapping="Wrap" Margin="0,4,0,0" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                    <TextBlock x:Name="DropLocationsText" Grid.Row="2" Grid.Column="0" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <TextBlock Text="建造时间:" Grid.Row="3" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="BuildTimeText" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <TextBlock Text="商店兑换:" Grid.Row="4" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="ShopExchangeText" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <TextBlock Text="常驻状态:" Grid.Row="5" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="IsPermanentText" Grid.Row="5" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 实装活动卡片 -->
            <Border x:Name="EventBorder"
                    Background="{ThemeResource CardBackgroundFillColorDefault}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,12"
                    Padding="12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <FontIcon Glyph="&#xE7E7;" FontFamily="Segoe Fluent Icons" FontSize="18" Margin="0,-4,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="实装活动" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    </StackPanel>
                    <TextBlock Text="活动名称:" Grid.Row="0" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="DebutEventText" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <TextBlock Text="实装日期:" Grid.Row="0" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="ReleaseDateText" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <TextBlock Text="备注:" Grid.Row="0" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="NotesText" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 专属兵装卡片 -->
            <Border x:Name="SpecialGearBorder"
                    Background="{ThemeResource CardBackgroundFillColorDefault}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,12"
                    Padding="12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <FontIcon Glyph="&#xF54C;" FontFamily="Segoe Fluent Icons" FontSize="18" Margin="0,-4,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="专属兵装" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    </StackPanel>
                    <TextBlock Text="兵装名称:" Grid.Row="0" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="SpecialGearNameText" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <TextBlock Text="实装日期:" Grid.Row="0" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="SpecialGearDateText" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <TextBlock Text="获取方式:" Grid.Row="0" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="SpecialGearAcquireText" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- 属性加成卡片 -->
            <Border x:Name="BonusBorder"
                    Background="{ThemeResource CardBackgroundFillColorDefault}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,12"
                    Padding="12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <FontIcon Glyph="&#xEABC;" FontFamily="Segoe Fluent Icons" FontSize="18" Margin="0,-4,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="属性加成" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <StackPanel>
                            <TextBlock Text="获得时" FontSize="17" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock x:Name="ObtainBonusText" FontSize="16" Margin="0,4,0,0"/>
                            <TextBlock Text="适用舰种:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            <TextBlock x:Name="ObtainAffectsText" FontSize="14" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="120级" FontSize="17" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock x:Name="Level120BonusText" FontSize="16" Margin="0,4,0,0"/>
                            <TextBlock Text="适用舰种:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            <TextBlock x:Name="Level120AffectsText" FontSize="14" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 舰队科技卡片 -->
            <Border x:Name="TechBorder"
                    Background="{ThemeResource CardBackgroundFillColorDefault}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,12"
                    Padding="12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <FontIcon Glyph="&#xE81E;" FontFamily="Segoe Fluent Icons" FontSize="18" Margin="0,-4,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="舰队科技" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    </StackPanel>
                    <Grid ColumnSpacing="12" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="获得:" Grid.Row="0" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="TechPointsObtainText" Grid.Row="0" Grid.Column="1" Margin="0,4,0,0"/>
                        <TextBlock Text="满破:" Grid.Row="1" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="TechPointsMaxText" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                        <TextBlock Text="120级:" Grid.Row="2" Grid.Column="0" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="TechPoints120Text" Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>