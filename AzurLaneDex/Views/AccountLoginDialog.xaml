<ContentDialog x:Class="AzurLaneDex.Views.AccountLoginDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               Title="登录账户"
               PrimaryButtonText="登录"
               PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
               CloseButtonText="取消"
               DefaultButton="Primary">
    <StackPanel Spacing="12">
        <ComboBox x:Name="AccountCombo" PlaceholderText="选择账户" MinWidth="200"/>
        <PasswordBox x:Name="PasswordBox" PlaceholderText="密码（如已设置）"/>
        <HyperlinkButton Content="忘记密码？" Click="ForgotPassword_Click" HorizontalAlignment="Left" />
        <CheckBox x:Name="RememberCheckBox" Content="记住本账户" IsChecked="True"/>
		<Button Content="创建新账户" Click="OnCreateAccountClick"/>
    </StackPanel>
</ContentDialog>