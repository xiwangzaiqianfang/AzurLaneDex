<Page x:Class="AzurLaneDex.Views.UpdatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:Microsoft.UI.Xaml.Controls"
      NavigationCacheMode="Disabled">

    <Page.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefault}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,20,20,12" Spacing="12">
            <Button x:Name="BackButton" Click="BackButton_Click"  Content="设置" FontSize="28" FontWeight="SemiBold" Margin="0,2,0,0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="返回" VerticalAlignment="Center"/>
            <FontIcon Grid.Column="0" Glyph="&#xE974;" FontFamily="Segoe Fluent Icons" FontSize="22" Margin="-20,3,-10,0" VerticalAlignment="Center"/>
            <TextBlock Text="更新" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20" Spacing="16">

                <!-- 应用版本卡片 -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE774;" FontFamily="Segoe Fluent Icons" FontSize="22" Margin="0,0,14,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="应用版本" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock x:Name="CurrentVersionText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                            <Button x:Name="CheckAppUpdateButton" Content="检查更新" Click="CheckAppUpdate_Click"/>
                            <Button x:Name="DownloadAppButton" Content="下载并安装" Click="DownloadApp_Click" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 应用更新源设置卡片 -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE730;" FontFamily="Segoe Fluent Icons" FontSize="22" Margin="0,0,14,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="应用更新源" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="选择检查应用更新的方式" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                            <ComboBox x:Name="AppDataSourceCombo" Margin="0,8,0,0" SelectedIndex="0"
                                      SelectionChanged="AppDataSourceCombo_SelectionChanged">
                                <ComboBoxItem>GitHub Pages</ComboBoxItem>
                                <ComboBoxItem>蓝奏云</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 数据更新卡片 -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE895;" FontFamily="Segoe Fluent Icons" FontSize="22" Margin="0,0,14,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="舰船数据" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="获取最新舰船资料" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                            <Button x:Name="CheckDataUpdateButton" Content="检查更新" Click="CheckDataUpdate_Click"/>
                            <Button x:Name="DownloadDataButton" Content="下载并安装" Click="DownloadData_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 数据更新源设置卡片 -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE730;" FontFamily="Segoe Fluent Icons" FontSize="22" Margin="0,0,14,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="数据更新源" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="选择数据文件的来源及代理（可选）" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                            <ComboBox x:Name="DataDataSourceCombo" Margin="0,8,0,0" SelectedIndex="0"
                                      SelectionChanged="DataDataSourceCombo_SelectionChanged">
                                <ComboBoxItem>GitHub (raw)</ComboBoxItem>
                                <ComboBoxItem>GitHub (CDN)</ComboBoxItem>
                                <ComboBoxItem>自定义URL</ComboBoxItem>
                            </ComboBox>
                            <TextBox x:Name="DataCustomUrlBox" PlaceholderText="自定义 ships_static.json 文件 URL" Margin="0,8,0,0"
                                     Visibility="Collapsed"/>
                            <TextBox x:Name="ProxyBox" PlaceholderText="代理地址（例如 http://127.0.0.1:7890）" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 状态信息 -->
                <TextBlock x:Name="StatusText" Text="就绪" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>